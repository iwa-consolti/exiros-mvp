# Plantilla de entorno del backend — copiar a backend/.env.
# DATABASE_URL apunta al Postgres de infra/docker-compose.yml (valores por defecto).
DATABASE_URL="postgresql://exiros:exiros_dev@localhost:5432/exiros?schema=public"

# Clave estática del bootstrap móvil (X-App-Key) — ADR-007 (débil por diseño).
APP_KEY="dev-app-key-cambia-en-prod"
# Secreto de servidor para derivar el tripToken por HMAC.
TRIP_TOKEN_SECRET="dev-trip-token-secret-cambia-en-prod"
