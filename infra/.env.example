# Plantilla de entorno para infra/docker-compose.yml — copiar a infra/.env y ajustar.
# infra/.env está gitignoreado; este .env.example SÍ se versiona.

# --- Postgres (consumido por docker-compose) ---
POSTGRES_USER=exiros
POSTGRES_PASSWORD=exiros_dev
POSTGRES_DB=exiros
POSTGRES_PORT=5432

# --- DATABASE_URL para Prisma (la usa el backend, no docker-compose) ---
# Derivada de las variables de arriba. El backend la lee desde backend/.env.
# DATABASE_URL="postgresql://exiros:exiros_dev@localhost:5432/exiros?schema=public"
